# Secret used to sign JWT access tokens (required in production — use a long random value)
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Optional: token lifetime in hours (default 168 = 7 days)
# JWT_EXPIRE_HOURS=168

# Optional: override SQLite path
# DATABASE_URL=sqlite:///./stocksense.db

# Required for AI suggestions — get your free key at https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key-here
